# Frontend environment variables for CompanyRun
# Copy to .env.local and fill in values

# ── Local dev (default) ───────────────────────────────────────
# Leave VITE_API_URL and BACKEND_URL unset to use the Vite proxy (localhost:3000).
# This is the default for "npm run dev" — no config needed.

# ── Separated deployment ──────────────────────────────────────
# Set these when the frontend runs on a different machine from the backend.

# VITE_API_URL: the backend's public URL.
# Baked into the JS bundle at build time — must be set before "npm run build".
# Example: point local Vite dev server at the Pi backend
# VITE_API_URL=http://192.168.0.141

# BACKEND_URL: used only by the Vite dev proxy (not baked into the bundle).
# Lets you run "npm run dev" locally while the backend runs on the Pi.
# BACKEND_URL=http://192.168.0.141
